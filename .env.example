# Anthropic API
ANTHROPIC_API_KEY=

# Optional: override default models
# BORG_MODEL_COGNITION=claude-opus-4-7
# BORG_MODEL_BACKGROUND=claude-opus-4-7
# BORG_MODEL_EXTRACTION=claude-opus-4-7

# OpenAI-compatible embeddings endpoint (defaults to LM Studio)
BORG_EMBEDDING_BASE_URL=http://localhost:1234/v1
BORG_EMBEDDING_API_KEY=lm-studio
BORG_EMBEDDING_MODEL=text-embedding-qwen3-embedding-8b
BORG_EMBEDDING_DIMS=4096

# Data directory (defaults to ~/.borg)
# BORG_DATA_DIR=/home/you/.borg
